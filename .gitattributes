# Default to auto line endings
* text=auto

# Source / text files - always LF
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.mcmeta text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific files - always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.png binary
*.ogg binary
*.ico binary
*.zip binary
